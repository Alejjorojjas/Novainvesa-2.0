# ============================================================
# NOVAINVESA — Backend — Variables de entorno
# Copia este archivo como .env para desarrollo local.
# NUNCA subir .env al repositorio.
# En producción, configurar estas variables en Render.com.
# ============================================================

# ─────────────────────────────────
# Servidor
# ─────────────────────────────────
PORT=8080
SPRING_PROFILES_ACTIVE=development

# ─────────────────────────────────
# Frontend (para CORS)
# ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────
# Base de datos — MySQL (Hostinger)
# ─────────────────────────────────
DB_HOST=srv1070.hstgr.io
DB_PORT=3306
DB_NAME=u228070604_novainvesa_db
DB_USER=u228070604_Alejjorojjas
DB_PASSWORD=tu_password_aqui

# ─────────────────────────────────
# Seguridad — JWT
# Generar con: openssl rand -base64 64
# ─────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_64_caracteres_minimo
JWT_ADMIN_SECRET=cambia_esto_por_otro_secreto_diferente_al_de_usuarios
JWT_EXPIRATION=604800000
JWT_ADMIN_EXPIRATION=86400000

# ─────────────────────────────────
# Email SMTP — Hostinger
# ─────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=pedidos@novainvesa.com
SMTP_PASSWORD=tu_password_de_correo_aqui

# ─────────────────────────────────
# Pagos — Wompi
# https://comercios.wompi.co/
# ─────────────────────────────────
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=tu_events_secret_de_wompi

# ─────────────────────────────────
# Pagos — MercadoPago
# https://developers.mercadopago.com/
# ─────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxx-xxxxxxxx
MP_WEBHOOK_SECRET=tu_webhook_secret_de_mercadopago

# ─────────────────────────────────
# Dropi — Credenciales de integración
# https://app.dropi.co/ → Integraciones
# ─────────────────────────────────
DROPI_EMAIL=tu_email_de_dropi@ejemplo.com
DROPI_PASSWORD=tu_password_de_dropi

# ─────────────────────────────────
# N8n — Automatización
# https://n8n.io/
# ─────────────────────────────────
N8N_WEBHOOK_URL=https://tu-instancia.n8n.cloud/webhook/xxxxxxxx
N8N_SECRET=secreto_compartido_entre_backend_y_n8n

# ─────────────────────────────────
# Meta — Pixel y Conversions API
# https://business.facebook.com/events_manager
# ─────────────────────────────────
META_PIXEL_ID=tu_pixel_id_de_meta
META_CAPI_TOKEN=tu_token_de_conversions_api
