# ============================================================
# NOVAINVESA — Frontend — Variables de entorno
# Copia este archivo como .env.local para desarrollo local.
# NUNCA subir .env.local al repositorio.
# En producción, configurar estas variables en Vercel.
# Las variables NEXT_PUBLIC_* son visibles en el navegador —
# no pongas secretos en ellas.
# ============================================================

# ─────────────────────────────────
# API Backend
# ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─────────────────────────────────
# MercadoPago — Clave pública (no secreta)
# https://developers.mercadopago.com/ → Credenciales
# ─────────────────────────────────
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxx-xxxxxxxx

# ─────────────────────────────────
# Meta Pixel
# https://business.facebook.com/events_manager
# ─────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=tu_pixel_id_de_meta

# ─────────────────────────────────
# Google Analytics 4
# https://analytics.google.com/
# ─────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─────────────────────────────────
# WhatsApp (número para el botón flotante)
# Formato: código de país + número sin espacios ni +
# Ejemplo Colombia: 573001234567
# ─────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=573001234567
